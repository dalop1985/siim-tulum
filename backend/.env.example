# ════════════════════════════════════════════════
# SIIM — Variables de entorno del backend
# Copia este archivo como .env y rellena los valores.
# NUNCA subas el .env real a Git (ya está en .gitignore).
# ════════════════════════════════════════════════

# ── PostgreSQL (instalación local en Windows: host=localhost) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=siim
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── Seguridad / JWT ──
SECRET_KEY=genera_una_clave_larga_y_aleatoria_aqui
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ──
# Puertos del proyecto: frontend 8900 → backend 6679 → PostgreSQL 5432
ENVIRONMENT=development
